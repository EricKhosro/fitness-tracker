# ---------------------------------------------------------------------------
# Database — Neon Postgres
# Create a free database at https://neon.tech and paste the connection string.
# Use the "pooled" connection string for the app at runtime.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth)
# Generate a secret with:  npx auth secret   (or: openssl rand -base64 32)
# ---------------------------------------------------------------------------
AUTH_SECRET="generate-me"

# Base URL of the app. For local dev keep http://localhost:3000
AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Google OAuth credentials
# Create them in Google Cloud Console (see README "Google OAuth setup").
# Authorized redirect URI:  http://localhost:3000/api/auth/callback/google
# ---------------------------------------------------------------------------
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
